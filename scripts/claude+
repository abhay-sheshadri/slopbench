#!/bin/bash

# Built-in: -r (resume), -c (continue) are native Claude Code flags
# Custom:   -f (continue + fork current session)
args=()
for arg in "$@"; do
    case "$arg" in
        -f) args+=(--continue --fork-session) ;;
        *)  args+=("$arg") ;;
    esac
done

IS_SANDBOX=1 claude --dangerously-skip-permissions "${args[@]}"
