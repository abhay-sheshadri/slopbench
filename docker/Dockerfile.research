# Research container for agent research tasks.
#
# Includes Python and common API/data-analysis packages.
# Good for:
#   - ML research experiments
#   - Dataset creation and analysis
#   - API-based model calls
#
# Build:  docker build -t agent-research -f docker/Dockerfile.research docker/

FROM python:3.11-slim

# System deps
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    curl \
    jq \
    wget \
    ca-certificates \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get update \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/*

ARG ABHAY_PI_PACKAGE=@earendil-works/pi-coding-agent
RUN npm install -g "$ABHAY_PI_PACKAGE"

# Python packages for API-based research
RUN pip install --no-cache-dir \
    anthropic \
    openai \
    python-dotenv \
    jinja2 \
    tqdm \
    scikit-learn \
    matplotlib \
    pandas \
    scipy \
    httpx

WORKDIR /workspace

CMD ["tail", "-f", "/dev/null"]
